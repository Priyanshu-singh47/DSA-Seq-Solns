class Solution {
public:
    int findMaxConsecutiveOnes(vector<int>& nums) {
        int count=0 ; int countupd=0;
        for(int i=0;i<nums.size();i++){
            if(nums[i]==1){
                count++;
                countupd=max(countupd,count);
            }
            else if(nums[i]==0){
               
                    count=0;
                   
                
            }
        }
        return countupd ;
        

    }
};